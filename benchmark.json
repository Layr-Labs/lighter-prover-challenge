{
  "schemaVersion": 1,
  "name": "lighter-prover-challenge",
  "description": "Generate valid proofs for the frozen Lighter block transaction and recursive chain circuits as quickly as possible.",
  "category": "rust",
  "direction": "+",
  "editablePaths": [
    "challenge/submission"
  ],
  "setupCommand": ["bash", "-lc", "./setup.sh"],
  "preSubmitCommand": ["bash", "-lc", "./benchmark.sh --local-submit"],
  "benchmarkCommand": ["bash", "-lc", "./benchmark.sh --local-iterate"],
  "scorePath": "score.json",
  "runner": {
    "provider": "github-actions",
    "workflow": "benchmark.yml"
  }
}
