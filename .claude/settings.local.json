{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude session"
          },
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.yukon/hooks/yukon-trace.sh\" claude capture"
          }
        ]
      }
    ]
  }
}
